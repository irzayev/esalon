FLASK_APP=wsgi.py
# production = strict mode: app refuses to boot with default SECRET_KEY/ADMIN_PASSWORD.
# Use FLASK_ENV=development for local work with insecure defaults.
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=change-me-to-a-long-random-string

# Send session cookie over HTTPS only (defaults on in production).
# Set to 0 only for internal plain-HTTP deployments.
SESSION_COOKIE_SECURE=1

# Default admin (создаётся при первом запуске).
# В production обязательно смените пароль — иначе приложение не запустится.
ADMIN_EMAIL=admin@washer.local
ADMIN_PASSWORD=change-me-strong-password

# SQLite файл и uploads хранятся в app/static/data (persistent volume)
DATABASE_URL=sqlite:////app/app/static/data/app.db
UPLOAD_FOLDER=/app/app/static/uploads

# Часовой пояс
TZ=Asia/Baku

# Токен для HTTP-cron напоминаний WhatsApp: GET /cron/wa-reminders?token=...
CRON_SECRET=
