FLASK_APP=wsgi.py
FLASK_ENV=production
SECRET_KEY=change-me-to-a-long-random-string

# Default admin (создаётся при первом запуске)
ADMIN_EMAIL=admin@washer.local
ADMIN_PASSWORD=admin123

# SQLite файл и uploads хранятся в app/static/data (persistent volume)
DATABASE_URL=sqlite:////app/app/static/data/app.db
UPLOAD_FOLDER=/app/app/static/uploads

# Часовой пояс
TZ=Asia/Baku

# Токен для HTTP-cron напоминаний WhatsApp: GET /cron/wa-reminders?token=...
CRON_SECRET=
